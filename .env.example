# LLM API Configuration (OpenAI-compatible endpoint)
VITE_LLM_API_BASE=https://api.vectorengine.ai/v1
VITE_LLM_API_KEY=your-api-key-here
VITE_LLM_MODEL=claude-sonnet-4-6

# Knowledge Base Path (absolute path to the knowledge base)
VITE_KB_PATH=/path/to/your/knowledge-base

# Machines config (JSON array)
# Each machine: name, type, specs, capabilities
VITE_MACHINES=[{"name":"mini","type":"server","specs":"18-core CPU, 64GB RAM, Ubuntu","capabilities":["data processing","model training","web scraping","long-running jobs","database queries","batch computation"]},{"name":"s600","type":"server","specs":"18-core CPU, 64GB RAM, Ubuntu","capabilities":["data processing","model training","web scraping","long-running jobs","database queries","batch computation"]},{"name":"mac","type":"workstation","specs":"Apple M4 Pro, 48GB RAM, macOS","capabilities":["coding","writing","analysis","web browsing","GPU inference","local development"]}]
