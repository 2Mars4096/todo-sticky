# LLM API Configuration (OpenAI-compatible endpoint)
VITE_LLM_API_BASE=https://api.XXX.ai
VITE_LLM_API_KEY=your-api-key-here
VITE_LLM_MODEL=XXX-model-name

# Knowledge Base Path (absolute path to the knowledge base)
VITE_KB_PATH=./ # /path/to/your/to-do-folder

# Machines config (JSON array)
# Each machine: name, type, specs, capabilities
VITE_MACHINES=[{"name":"Cloud GPU","type":"server","specs":"A100 80GB, 256GB RAM","capabilities":["model training","data processing","batch computation","long-running jobs"]},{"name":"Scraper","type":"server","specs":"16-core, 32GB RAM, headless","capabilities":["web scraping","data processing","database queries","long-running jobs"]},{"name":"Local Mac","type":"workstation","specs":"M4 Pro, 48GB RAM","capabilities":["coding","writing","analysis","web browsing","local development"]}]
